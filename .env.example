# --- HTTP server ---
PORT=8090
# Token that protects ONLY live account data (&account=1). Public market/signal
# analysis is open-read so URLs carry no secret. Sent as "Authorization: Bearer
# <token>" OR "?key=<token>".
AUTH_TOKEN=change-me-to-a-long-random-string

# --- Bybit ---
BYBIT_BASE=https://api.bybit.com
# linear = USDT perpetuals (what you trade). Use "spot" for spot pairs.
BYBIT_CATEGORY=linear
# Read-only API key/secret. Only needed for live account (positions/balance).
# Market analysis works WITHOUT these. Create a READ-ONLY key in Bybit.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_RECV_WINDOW=5000

# --- Telegram bot (optional, Phase 3) ---
# Create a bot with @BotFather, paste its token here, enable the bot service.
# Then forward any signal to the bot → it replies with fresh Bybit analysis.
TELEGRAM_BOT_TOKEN=
# Optional allowlist of chat ids (comma-separated; get yours from @userinfobot).
# Empty = anyone who finds the bot can use it.
TELEGRAM_ALLOWED_CHATS=
# Alert when an open order's price is within this % of live price (order monitor).
ORDER_NEAR_PCT=1
# Ping when an open position is within this % of its liquidation price.
LIQ_NEAR_PCT=8
# Daily digest hour (UTC, 0-23). DIGEST_HOUR=off to disable.
DIGEST_HOUR=7
# Suggested position size targets this % of equity at risk (entry→stop).
RISK_PCT=2
# Let the bot PLACE stop-loss/take-profit on positions (button-confirmed each
# time). Off by default — set to "on" only when you want /pos SL/TP buttons.
PLACE_ENABLED=off

# --- Channel reader / userbot (optional, Phase 4) ---
# From my.telegram.org (api_id + api_hash). Reads a channel AS YOU (read-only).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Produced once by `node bot/userbot-login.js` — paste the printed session here.
TELEGRAM_SESSION=
# The Binance Killers channel: @username if public, else its numeric id (the
# login script lists your channels with ids).
BK_CHANNEL=
# Only push channel signals scoring >= this (0 = push all, just 🟢/🟡/🔴 tagged).
MIN_SCORE=0
